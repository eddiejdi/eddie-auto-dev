# ═══════════════════════════════════════════════════════════════════════════
# CONSOLIDATED ENVIRONMENT VARIABLES TEMPLATE
# Date: 2026-03-07
# Merged from: .env, .env.mailu, .env.jira, .env.email, .env.simple-mail, btc_trading_agent/.env
# 
# IMPORTANT: This is a TEMPLATE with placeholder values.
# Replace all placeholder values with your actual credentials in local .env file.
# NEVER commit .env with real secrets! (already in .gitignore)
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD & HOME ASSISTANT
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_gemini_api_key_here
GEMINI_ENABLED=true
GOOGLE_AI_API_KEY_NAME="Gemini API Key"
GOOGLE_SDM_PROJECT=projects/your_project_id
GOOGLE_SDM_PROJECT_NUMBER=your_project_number
GOOGLE_SDM_PROJECT_ID=your_project_id
GOOGLE_HOME_TOKEN=your_google_home_token_here
HOME_ASSISTANT_URL=http://192.168.15.2:8123
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# ─────────────────────────────────────────────────────────────────────────────
# MAILU EMAIL SERVER
# ─────────────────────────────────────────────────────────────────────────────
MAILU_DOMAIN=mail.example.com
ADMIN_EMAIL=admin@mail.example.com
POSTMASTER_EMAIL=postmaster@mail.example.com
MAILU_SECRET_KEY=generate_with_openssl_rand_base64_32
MAILU_DB_PASSWORD=your_mailu_db_password_here
MAILU_REDIS_PASSWORD=your_mailu_redis_password_here
MAILU_TLS_FLAVOR=letsencrypt
MAILU_HTTP_PORT=80
MAILU_HTTPS_PORT=443
MAILU_SMTP_PORT=25
MAILU_SUBMISSION_PORT=587
MAILU_IMAP_PORT=143
MAILU_IMAPS_PORT=993
MAILU_POP3_PORT=110
MAILU_POP3S_PORT=995
POSTFIX_EXPORTER_PORT=9307
DOVECOT_EXPORTER_PORT=9308
MAX_EMAIL_SIZE=25
AUTH_RATELIMIT=100/minute
MAILU_DATABASE_URL=postgresql://mailu:${MAILU_DB_PASSWORD}@mailu-db/mailu
MAILU_REDIS_URL=redis://:${MAILU_REDIS_PASSWORD}@mailu-redis

# ─────────────────────────────────────────────────────────────────────────────
# JIRA INTEGRATION
# ─────────────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-instance.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_api_token_not_password

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL CLIENT
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_DB_PASSWORD=your_email_db_password_here
EMAIL_DOMAIN=mail.example.com
EMAIL_ADMIN=admin@mail.example.com

# ─────────────────────────────────────────────────────────────────────────────
# BTC TRADING AGENT
# ─────────────────────────────────────────────────────────────────────────────
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_API_SECRET=your_kucoin_api_secret_here
KUCOIN_API_PASSPHRASE=your_kucoin_api_passphrase_here
KUCOIN_ALLOWED_IP=your_public_ip_here

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA / LOCAL LLM
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://192.168.15.2:11434
OLLAMA_HOST_GPU1=http://192.168.15.2:11435
OLLAMA_MODEL=shared-coder

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=192.168.15.2
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=btc_trading
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─────────────────────────────────────────────────────────────────────────────
# COMMUNICATION BUS & IPC
# ─────────────────────────────────────────────────────────────────────────────
COMMUNICATION_BUS_URL=http://192.168.15.2:8503
SHARED_IPC_SECRET=your_ipc_secret_key_here

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT (optional)
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH2 / AUTHENTIK (optional)
# ─────────────────────────────────────────────────────────────────────────────
# ENABLE_OAUTH2=true
# OAUTH2_PROVIDER_URL=https://auth.example.com
# OAUTH2_CLIENT_ID=your_client_id_here
# OAUTH2_CLIENT_SECRET=your_client_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
DATA_DIR=/data
CACHE_DIR=/tmp/.cache
