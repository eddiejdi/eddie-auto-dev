# Configuração de Modelo OpenAI-compatible (sk-or-v1)
# Copie este arquivo para .env e preencha com seus valores

# ─── MODELO OpenAI-compatible (Fallback quando GPU não disponível) ───────
# Ativar modelo OpenAI-compatible
OPENAI_COMPATIBLE_ENABLED=true

# Token de API (sk-or-v1-... para OpenRouter)
OPENAI_COMPATIBLE_API_KEY=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

# URL base da API (padrão: OpenRouter)
# Opções:
#  - OpenRouter: https://openrouter.ai/api/v1
#  - Scaleway AI: https://api.scaleway.ai/v1
#  - Together.ai: https://api.together.xyz/v1
#  - Outro OpenAI-compatible: https://seu-endpoint.com/v1
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1

# Modelo a usar (varia por provedor)
# OpenRouter: gpt-4, gpt-3.5-turbo, claude-3-opus, etc.
# Scaleway: gpt-4, etc.
OPENAI_COMPATIBLE_MODEL=gpt-4

# ─── GPUs LOCAIS (Ollama) ──────────────────────────────────────────────
# GPU0 - Principal (RTX 2060)
OLLAMA_HOST=http://192.168.15.2:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# GPU1 - Secundária (GTX 1050)
OLLAMA_HOST_GPU1=http://192.168.15.2:11435
OLLAMA_MODEL_GPU1=qwen3:0.6b

# ─── CONFIGURAÇÃO DE FALLBACK ─────────────────────────────────────────
# Roteamento automático:
# 1. Tenta GPU0 (Ollama local - recomendado, mais rápido)
# 2. Se GPU0 falhar: tenta GPU1 (Ollama GPU1 - leve)
# 3. Se ambas falharem: usa OpenAI-compatible se ENABLED=true
# Tempo de espera antes de considerar GPU indisponível (segundos)
GPU_FALLBACK_TIMEOUT=5
