#!/bin/bash
# Post-commit hook — (1) Indexar commit na memória; (2) Sincronizar .md com Wiki RPA4All
#
# CMDB baseline foi movido para pre-commit (.githooks/pre-commit check 9)
# para evitar commits órfãos chore(cmdb) separados do trabalho real.

set -euo pipefail

# ─── Memory ingestor (git → Chroma) ───────────────────────────────────────────
INGESTOR="tools/memory_ingestors/git_ingestor.py"
if [ -f "$INGESTOR" ]; then
    PY_MEM="$(dirname "$0")/../.venv/bin/python"
    [ -x "$PY_MEM" ] || PY_MEM="python3"
    "$PY_MEM" "$INGESTOR" >/dev/null 2>&1 || true
fi

# ─── Wiki sync ────────────────────────────────────────────────────────────────
SKIP_PATTERNS=(
  "^wiki_"
  "CONVERSAS_"
  "COMPARISON"
  "^\.github/"
  "^docs/confluence"
)

MD_FILES=$(git diff-tree --no-commit-id -r --name-only --diff-filter=AM HEAD | grep "\.md$" || true)

if [ -z "$MD_FILES" ]; then
    exit 0
fi

TO_SEND=""
for f in $MD_FILES; do
    skip=0
    for pat in "${SKIP_PATTERNS[@]}"; do
        if echo "$f" | grep -qE "$pat"; then
            skip=1
            break
        fi
    done
    [ $skip -eq 0 ] && TO_SEND="$TO_SEND $f"
done

TO_SEND=$(echo "$TO_SEND" | xargs)
if [ -z "$TO_SEND" ]; then
    exit 0
fi

echo ""
echo "📚 [wiki-agent] Enviando .md para wiki_rpa4all (sem publish direto)..."
for f in $TO_SEND; do
    echo "   → $f"
done

PY_BIN="$(dirname "$0")/../.venv/bin/python"
[ -x "$PY_BIN" ] || PY_BIN="python3"

for f in $TO_SEND; do
    MSG="Publicar/atualizar em locale pt o arquivo ${f}. Validar URL em /pt antes de concluir a publicação."
    "$PY_BIN" "$(dirname "$0")/../tools/agent_ipc.py" publish \
        --agent wiki_rpa4all \
        --task-type wiki_update \
        --priority low \
        --message "$MSG" >/dev/null 2>&1 &
done

exit 0