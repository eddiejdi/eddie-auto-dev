#!/bin/bash
# Pre-commit hook — Enforce coding standards

set -e

echo "🔍 Running pre-commit checks..."

# ─── Check 1: Blocked hardcoded tokens ───────────────────────────────────────
echo "  [1/6] Checking for hardcoded API tokens..."
# Patterns: sk-ant-*, sk-proj-*, ghp_*, glpat-*, 40+ hex chars
# Note: \bsk- with word boundary avoids false positives like "disk-"
if git diff --cached | grep -PE "(\bsk-ant|\bsk-proj|ghp_|glpat-|[a-f0-9]{40,})" >/dev/null 2>&1; then
    echo "❌ BLOCKED: Hardcoded API token detected"
    echo "   Use .env.consolidated or Secrets Agent instead"
    exit 1
fi

# ─── Check 2: No .env files (only .env.consolidated) ───────────────────────────
echo "  [2/6] Checking .env file restrictions..."

# Check for NEW or MODIFIED .env files (not deleted ones)
ADDED_OR_MODIFIED_ENV=$(git diff --cached --diff-filter=AM --name-only | grep -E "^\.env$|^\.env\.[a-z]" || true)

if [ ! -z "$ADDED_OR_MODIFIED_ENV" ]; then
    if ! git diff --cached --name-only | grep -q "\.env.consolidated"; then
        echo "❌ BLOCKED: Cannot commit .env files with secrets"
        echo "   Use .env.consolidated (template) instead"
        exit 1
    fi
fi

# ─── Check 3: GPU configuration validation ───────────────────────────────────
echo "  [3/6] Validating GPU-first configuration..."
if [ ! -f ".env.consolidated" ]; then
    echo "⚠️  WARNING: .env.consolidated not found (will be needed for GPU-first)"
fi
if ! grep -q "OLLAMA_HOST" .env.consolidated 2>/dev/null; then
    echo "⚠️  WARNING: OLLAMA_HOST not configured"
fi

# ─── Check 4: Python code changes — Test coverage validation ──────────────────
echo "  [4/6] Checking Python code has corresponding tests..."

# Get changed Python files (excluding certain patterns)
PY_FILES=$(git diff --cached --name-only | grep "\.py$" | grep -v "__pycache__\|\.pyc\|test_\|conftest" || true)

if [ ! -z "$PY_FILES" ]; then
    MISSING_TESTS=0
    
    for py_file in $PY_FILES; do
        # Skip test files themselves
        if [[ "$py_file" == *"/test_"* ]] || [[ "$py_file" == *"/conftest.py" ]]; then
            continue
        fi
        
        # Skip certain directories (scripts, tools with no test dirs)
        if [[ "$py_file" == ".archive/"* ]] || [[ "$py_file" == "tests/"* ]]; then
            continue
        fi
        
        # Check if component has tests directory
        MODULE_DIR=$(dirname "$py_file")
        if [ -d "$MODULE_DIR/tests" ] || [ -d "tests" ]; then
            # Look for corresponding test file
            TEST_NAME="test_$(basename "$py_file")"
            
            # Check if test exists or is being added
            if ! git diff --cached --name-only | grep -q "$TEST_NAME"; then
                # Only warn for critical modules (btc_trading_agent, specialized_agents)
                if [[ "$py_file" == "btc_trading_agent/"* ]] || [[ "$py_file" == "specialized_agents/"* ]]; then
                    echo "⚠️  WARNING: No tests found for $py_file"
                    echo "     Please add tests/test_$(basename "$py_file") or mark as --no-verify"
                    MISSING_TESTS=$((MISSING_TESTS + 1))
                fi
            fi
        fi
    done
    
    if [ $MISSING_TESTS -gt 0 ]; then
        echo "⚠️  $MISSING_TESTS file(s) modified without visible test changes"
        echo "     To skip: git commit --no-verify (not recommended)"
    fi
fi

# ─── Check 5: Run GPU-first validator (10 second timeout) ─────────────────────
echo "  [5/6] Running GPU-first compliance validator..."
if command -v python3 >/dev/null 2>&1; then
    if [ -f "tools/gpu_first_validator.py" ]; then
        timeout 10 python3 tools/gpu_first_validator.py >/dev/null 2>&1 || {
            echo "⚠️  GPU-first validator timeout or error (non-blocking)"
        }
    fi
fi

# ─── Check 6: OLLAMA_HOST coordinator port — bloqueia porta direta de GPU ─────
# OLLAMA_HOST deve sempre apontar para o coordinator (:11437).
# Portas diretas de GPU (:11434, :11435) são permitidas APENAS em OLLAMA_HOST_GPU*.
echo "  [6/6] Validating OLLAMA_HOST coordinator port in systemd files..."

SYSTEMD_FILES=$(git diff --cached --name-only | grep -E "\.(service|conf)$" || true)

if [ -n "$SYSTEMD_FILES" ]; then
    WRONG_PORT=0
    for f in $SYSTEMD_FILES; do
        # Detecta Environment="OLLAMA_HOST=...:(11434|11435)" excluindo OLLAMA_HOST_GPU*
        if git show ":$f" 2>/dev/null \
            | grep -E '"?OLLAMA_HOST=http://[^"]*:(11434|11435)' \
            | grep -qv 'OLLAMA_HOST_GPU'; then
            echo "❌ BLOCKED: $f define OLLAMA_HOST apontando para porta de GPU direto (:11434 ou :11435)"
            echo "   OLLAMA_HOST deve usar o coordinator proxy em :11437"
            echo "   Para acesso direto à GPU use OLLAMA_HOST_GPU0 (:11434) ou OLLAMA_HOST_GPU1 (:11435)"
            WRONG_PORT=$((WRONG_PORT + 1))
        fi
    done
    if [ $WRONG_PORT -gt 0 ]; then
        exit 1
    fi
fi

# ─── Check 7: Grafana dashboard UID uniqueness ────────────────────────────────
# Detecta UIDs duplicados em monitoring/grafana/provisioning/dashboards/**
# Arquivos .disabled.* e .bak são ignorados. Bloqueia commit se houver duplicata.
echo "  [7/8] Checking Grafana dashboard UID uniqueness..."
GRAFANA_JSON=$(git diff --cached --name-only | grep -E "\.json$" | grep -E "grafana" || true)
if [ -n "$GRAFANA_JSON" ]; then
    python3 - <<'PYEOF' || exit 1
import json, glob, sys

uid_map = {}
for f in glob.glob('monitoring/grafana/provisioning/dashboards/**/*.json', recursive=True):
    if '.disabled' in f or f.endswith('.bak') or f.endswith('.yml'):
        continue
    try:
        with open(f) as fh:
            d = json.load(fh)
        uid = d.get('uid') or d.get('dashboard', {}).get('uid')
        if uid:
            uid_map.setdefault(uid, []).append(f)
    except Exception:
        pass

errors = {uid: files for uid, files in uid_map.items() if len(files) > 1}
if errors:
    print('❌ BLOCKED: UIDs duplicados em monitoring/grafana/provisioning/dashboards/:')
    for uid, files in errors.items():
        print(f'  UID [{uid}] presente em {len(files)} arquivos:')
        for f in sorted(files):
            print(f'    - {f}')
    print()
    print('  Renomeie os arquivos obsoletos para *.disabled antes de commitar.')
    sys.exit(1)
print('  ✅ UIDs de dashboards únicos')
PYEOF
fi

# ─── Check 8: Tarefa incompleta (stubs / NotImplementedError / elipse de código) ──
# Rejeita commit com marcadores de alto sinal de trabalho incompleto nas linhas staged.
# Cobre qualquer ferramenta (Copilot, Codex, Claude Code, edição manual) — todas commitam.
# Escape: ALLOW_INCOMPLETE=1, `# stub-ok` na linha, ou git commit --no-verify.
echo "  [8/11] Checking for incomplete tasks (stubs / NotImplementedError)..."
if [ -z "$ALLOW_INCOMPLETE" ]; then
    if [ -f "tools/hooks/incomplete_markers.py" ]; then
        # Código 2 = incompletude → bloqueia.
        # Código !=0 e !=2 = bug do detector → INCIDENTE obrigatório (não silencioso).
        rc=0
        python3 tools/hooks/incomplete_markers.py --staged || rc=$?
        if [ "$rc" -eq 2 ]; then
            exit 1
        elif [ "$rc" -ne 0 ]; then
            echo "     ⚠️ INCIDENTE: detector de incompletude retornou código $rc"
            if [ -f "tools/hooks/incident_notify.py" ]; then
                python3 tools/hooks/incident_notify.py \
                    --source "pre-commit/incomplete_markers" \
                    --summary "detector de incompletude falhou com código $rc" \
                    --severity warn || true
            fi
        fi
    fi
else
    echo "     (ALLOW_INCOMPLETE set — pulando checagem de incompletude)"
fi

# ─── Check 9: CMDB baseline + trading overrides (mesmo commit, sem post-commit orphan) ──
echo "  [9/11] Regenerating CMDB baseline and trading overrides..."
if [ -z "${SKIP_CMDB_HOOK:-}" ] && [ -f "scripts/cmdb/generate_cmdb_baseline.py" ]; then
    PY_CMDB="$(dirname "$0")/../.venv/bin/python"
    [ -x "$PY_CMDB" ] || PY_CMDB="python3"
    if ! "$PY_CMDB" scripts/cmdb/generate_cmdb_baseline.py --check-staged; then
        echo "❌ BLOCKED: CMDB baseline desatualizado em relação aos configs trading staged"
        exit 1
    fi
    git add \
        deploy/cmdb/bootstrap/generated/cmdb-baseline.json \
        deploy/cmdb/bootstrap/generated/cmdb-baseline.md \
        deploy/cmdb/bootstrap/cmdb-agent-overrides.json \
        2>/dev/null || true
    echo "  ✅ CMDB baseline/overrides staged neste commit"
elif [ -n "${SKIP_CMDB_HOOK:-}" ]; then
    echo "     (SKIP_CMDB_HOOK set — pulando regeneração CMDB)"
fi

# ─── Check 10: Taxonomia de variáveis — bloqueia duplicatas ──────────────────
# Consulta .variables-catalog/catalog.json antes de aceitar variável nova.
# Cobre qualquer ferramenta (Copilot, Codex, Claude Code, edição manual).
echo "  [10/11] Checking variable taxonomy (duplicates)..."
if [ -f "tools/hooks/variable_registry_validate.py" ]; then
    if ! python3 tools/hooks/variable_registry_validate.py --staged; then
        exit 1
    fi
fi

# ─── Check 11: Proibição global de erro silencioso / fallback sem incidente ──
# Nunca permitir except:pass, engolir Exception sem log, || true em paths críticos.
# Escape: ALLOW_SILENT_FAILURE=1, ou `# silent-ok` / `# incident-ok` na linha.
echo "  [11/11] Checking silent failures / unreported fallbacks..."
if [ -z "${ALLOW_SILENT_FAILURE:-}" ]; then
    if [ -f "tools/hooks/no_silent_failure.py" ]; then
        rc=0
        python3 tools/hooks/no_silent_failure.py --staged || rc=$?
        if [ "$rc" -eq 2 ]; then
            exit 1
        elif [ "$rc" -ne 0 ]; then
            echo "❌ BLOQUEADO: detector no_silent_failure falhou (código $rc) — não fail-open"
            if [ -f "tools/hooks/incident_notify.py" ]; then
                python3 tools/hooks/incident_notify.py \
                    --source "pre-commit/no_silent_failure" \
                    --summary "detector retornou código $rc" \
                    --severity error || true
            fi
            exit 1
        fi
    fi
else
    echo "     (ALLOW_SILENT_FAILURE set — pulando checagem de erro silencioso)"
fi

echo ""
echo "✅ Pre-commit checks passed!"
echo "   Ready to commit. Use --no-verify to skip checks if needed."
echo ""
