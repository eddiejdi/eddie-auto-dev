# === MODELOS OLLAMA — edite APENAS este arquivo para trocar de modelo ===
# GPU0 (RTX 3060 12GB) :11434 — trading-analyst
# GPU1 (GTX 1050 2GB)  :11435 — gemma3-fast:gpu1 / lfm2.5-fast:gpu1
# Coordenador :11437 carrega o modelo adequado em cada GPU (pull/warm).

OLLAMA_PRIMARY_MODEL=trading-analyst
OLLAMA_SMALL_MODEL=gemma3-fast:gpu1

# Plan: trading-analyst no GPU0 (a cada ~15min)
OLLAMA_PLAN_MODEL=trading-analyst
OLLAMA_PLAN_FALLBACK_MODEL=gemma3-fast:gpu1

# Trade params: trading-analyst primário, gemma3-fast como fallback
OLLAMA_TRADE_PARAMS_MODEL=trading-analyst
OLLAMA_TRADE_PARAMS_CONSERVATIVE_MODEL=trading-analyst
OLLAMA_TRADE_PARAMS_FALLBACK_MODEL=gemma3-fast:gpu1

# Trade window: trading-analyst primário, gemma3-fast como fallback
OLLAMA_TRADE_WINDOW_MODEL=trading-analyst
OLLAMA_TRADE_WINDOW_CONSERVATIVE_MODEL=trading-analyst
OLLAMA_TRADE_WINDOW_FALLBACK_MODEL=gemma3-fast:gpu1
