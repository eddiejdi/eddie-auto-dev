KWAI_START_URL=https://www.kwai.com/discover
KWAI_VIDEOS_PER_SESSION=5
KWAI_WATCH_SECONDS=20
KWAI_VIEWER_DATA_DIR=/var/lib/eddie/kwai-viewer
KWAI_CHROME_BINARY=/opt/google/chrome/google-chrome
KWAI_HEADLESS=0
KWAI_VIRTUAL_DISPLAY=1
KWAI_TELEGRAM_NOTIFY=1
KWAI_GRAFANA_DASHBOARD_URL=https://grafana.rpa4all.com/d/kwai-viewer/kwai-viewer-monitor
# Telegram: TELEGRAM_BOT_TOKEN e TELEGRAM_CHAT_ID vêm de /etc/default/eddie-common
# Saldo manual (opcional — sobrescreve balance.json a cada sessão):
# KWAI_ACCOUNT_BALANCE=0.00
# KWAI_ACCOUNT_CURRENCY=BRL
KWAI_BALANCE_SCRAPE=1
# Perfil do container kwai-browser (após deploy + login manual):
KWAI_CHROME_PROFILE_DIR=/home/homelab/docker/kwai-browser/config/.config/chromium
KWAI_COOKIE_SOURCE=/home/homelab/docker/kwai-browser/config/.config/chromium/Default/Cookies
KWAI_BALANCE_URLS=https://m-wallet.kwai.com/main/transfer,https://m-wallet.kwai.com/,https://m-creative.kwai.com/creator/center,https://www.kwai.com/discover
# Fallback local (caso rode fora do container):
# KWAI_CHROME_PROFILE_DIR=/home/homelab/.local/share/kwai-viewer/chrome-profile
SECRETS_AGENT_DATA=/var/lib/eddie/secrets_agent