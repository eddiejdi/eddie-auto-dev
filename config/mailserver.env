# ============================================================
# docker-mailserver — Environment Configuration
# Domain: rpa4all.com | Hostname: mail.rpa4all.com
# Deploy em: /mnt/raid1/docker-mailserver/mailserver.env
# Docs: https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/
# ============================================================

# --- General ---
OVERRIDE_HOSTNAME=mail.rpa4all.com
LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=warn
ONE_DIR=1
PERMIT_DOCKER=network

# --- Accounts ---
ACCOUNT_PROVISIONER=FILE
POSTMASTER_ADDRESS=postmaster@rpa4all.com

# --- Networking ---
NETWORK_INTERFACE=
TZ=America/Sao_Paulo

# --- SSL/TLS ---
SSL_TYPE=self-signed
SSL_DOMAIN=mail.rpa4all.com

# --- SMTP ---
SMTP_ONLY=0
ENABLE_CLAMAV=0
ENABLE_RSPAMD=1
ENABLE_RSPAMD_REDIS=1
ENABLE_AMAVIS=0
ENABLE_SPAMASSASSIN=0
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0

# --- IMAP ---
ENABLE_IMAP=1
ENABLE_POP3=0

# --- DKIM (via Rspamd) ---
ENABLE_OPENDKIM=0

# --- Fail2Ban ---
ENABLE_FAIL2BAN=1
FAIL2BAN_BLOCKTYPE=drop

# --- ManageSieve ---
ENABLE_MANAGESIEVE=1

# --- Fetchmail ---
ENABLE_FETCHMAIL=0

# --- Quotas ---
ENABLE_QUOTAS=1
POSTFIX_MAILBOX_SIZE_LIMIT=0
POSTFIX_MESSAGE_SIZE_LIMIT=26214400

# --- Rate limiting ---
POSTFIX_REJECT_UNKNOWN_CLIENT_HOSTNAME=0
POSTFIX_REJECT_UNKNOWN_SENDER_DOMAIN=1
POSTFIX_REJECT_UNKNOWN_RECIPIENT_DOMAIN=1

# --- Relay (não estamos usando relay) ---
DEFAULT_RELAY_HOST=
RELAY_HOST=
RELAY_PORT=25
RELAY_USER=
RELAY_PASSWORD=

# --- SRS (Sender Rewriting Scheme) ---
ENABLE_SRS=0

# --- Update check ---
ENABLE_UPDATE_CHECK=1
UPDATE_CHECK_INTERVAL=1d
