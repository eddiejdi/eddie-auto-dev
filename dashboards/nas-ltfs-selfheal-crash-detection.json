  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Detecção de LTFS Mount Status — RED quando unmounted/hang",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "color-background"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "MOUNTED",
                  "color": "green"
                },
                "0": {
                  "text": "UNMOUNTED",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "options": {
        "graphicalThreshold": true,
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "fields": "",
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "nas_ltfs_mount_up{mountpoint=\"/mnt/tape/lto6\"}",
          "refId": "A"
        }
