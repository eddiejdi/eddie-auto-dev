      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{job=\"nas-node-exporter\"} - node_memory_MemAvailable_bytes{job=\"nas-node-exporter\"}) / 1024 / 1024 / 1024",
          "legendFormat": "Memory Used (GB)",
          "refId": "A"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
