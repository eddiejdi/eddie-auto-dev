CMDB_TIMEZONE=America/Sao_Paulo

# Bindings
CMDB_PROXY_BIND=127.0.0.1
CMDB_PROXY_HTTP_PORT=18090
NETBOX_BIND=127.0.0.1
NETBOX_DIRECT_PORT=18091
GLPI_BIND=127.0.0.1
GLPI_DIRECT_PORT=18092

# Hostnames used by the proxy vhosts
NETBOX_SERVER_NAME=netbox.cmdb.local
GLPI_SERVER_NAME=glpi.cmdb.local
NETBOX_ALLOWED_HOSTS=auth.rpa4all.com netbox.cmdb.local localhost 127.0.0.1
NETBOX_CSRF_TRUSTED_ORIGINS=https://auth.rpa4all.com
NETBOX_BASE_PATH=cmdb/netbox/
NETBOX_LOGIN_REQUIRED=true
NETBOX_LOGOUT_REDIRECT_URL=https://auth.rpa4all.com/outpost.goauthentik.io/sign_out
NETBOX_REMOTE_AUTH_ENABLED=true
NETBOX_REMOTE_AUTH_AUTO_CREATE_USER=true
NETBOX_REMOTE_AUTH_HEADER=HTTP_X_AUTHENTIK_USERNAME
NETBOX_REMOTE_AUTH_USER_EMAIL=HTTP_X_AUTHENTIK_EMAIL
NETBOX_REMOTE_AUTH_GROUP_SYNC_ENABLED=true
NETBOX_REMOTE_AUTH_GROUP_HEADER=HTTP_X_AUTHENTIK_GROUPS
NETBOX_REMOTE_AUTH_GROUP_SEPARATOR=|
NETBOX_REMOTE_AUTH_STAFF_GROUPS=authentik Admins
NETBOX_REMOTE_AUTH_SUPERUSER_GROUPS=authentik Admins
CLIENT_MAX_BODY_SIZE=64m

# Image tags
NETBOX_IMAGE_TAG=v4.6-5.0.1
NETBOX_POSTGRES_IMAGE_TAG=18-alpine
NETBOX_REDIS_IMAGE_TAG=9.0-alpine
GLPI_IMAGE_TAG=latest
GLPI_DB_IMAGE_TAG=11
NGINX_IMAGE_TAG=1.29-alpine

# NetBox database and app bootstrap
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
NETBOX_DB_PASSWORD=change-me-netbox-db
NETBOX_REDIS_PASSWORD=change-me-netbox-redis
NETBOX_REDIS_CACHE_PASSWORD=change-me-netbox-redis-cache
NETBOX_SECRET_KEY=change-me-netbox-secret-key
NETBOX_SUPERUSER_NAME=cmdb-admin
NETBOX_SUPERUSER_EMAIL=cmdb-admin@local
NETBOX_SUPERUSER_PASSWORD=change-me-netbox-admin
NETBOX_EMAIL_FROM=cmdb@local
NETBOX_EMAIL_SERVER=localhost
NETBOX_EMAIL_PORT=25
NETBOX_EMAIL_USE_SSL=false
NETBOX_EMAIL_USE_TLS=false
NETBOX_SKIP_SUPERUSER=false

# GLPI database and app bootstrap
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=change-me-glpi-db
GLPI_SKIP_AUTOINSTALL=true
GLPI_SKIP_AUTOUPDATE=false
GLPI_CRONTAB_ENABLED=1
