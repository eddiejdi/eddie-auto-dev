#!ipxe
# Boot direto para o menu iVentoy (Ventoy).
# O boot direto via sanhook/sanboot para Atom noPAE foi removido porque
# causava que a maquina ignorasse o menu ao receber keypress 'a' do BIOS USB.
chain http://192.168.15.2:16000/ipxe/01-${net0/mac:hexhyp}/bios/mask:255.255.255.0/gw:192.168.15.1/dns:/ippoolbegin:192.168.15.200/ippoolend:192.168.15.219 || exit
