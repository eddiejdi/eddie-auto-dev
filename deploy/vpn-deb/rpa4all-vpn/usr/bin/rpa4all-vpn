#!/bin/bash
# rpa4all-vpn — CLI para gerenciar VPN WireGuard ao homelab RPA4All
# Instalado por: pacote rpa4all-vpn
set -euo pipefail

VERSION="1.0.0"
VPN_NAME="rpa4all-vpn"
WG_CONF="/etc/wireguard/rpa4all.conf"
NM_CONN="rpa4all-vpn"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_ok()   { echo -e "${GREEN}[✓]${NC} $*"; }
log_info() { echo -e "${CYAN}[i]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[!]${NC} $*"; }
log_err()  { echo -e "${RED}[✗]${NC} $*"; }

need_root() {
    if [ "$(id -u)" -ne 0 ]; then
        log_err "Este comando precisa de root. Use: sudo rpa4all-vpn $*"
        exit 1
    fi
}

cmd_up() {
    need_root up
    log_info "Conectando VPN ${VPN_NAME}..."

    # Atualizar endpoint antes de conectar
    /usr/bin/rpa4all-vpn-update-endpoint 2>/dev/null || true

    if ip link show "${VPN_NAME}" &>/dev/null; then
        log_warn "VPN já conectada. Reconectando..."
        nmcli connection down "${NM_CONN}" 2>/dev/null || true
        sleep 1
    fi

    nmcli connection up "${NM_CONN}" 2>/dev/null || {
        log_err "Falha ao ativar via NetworkManager. Tentando wg-quick..."
        wg-quick up "${WG_CONF}" || {
            log_err "Falha ao conectar VPN."
            exit 1
        }
    }

    # Remover rota LAN conflitante se estiver na rede local
    local current_gw
    current_gw=$(ip route show default 2>/dev/null | awk '/via/{print $3}' | head -1)
    if [[ "${current_gw}" == 192.168.15.* ]]; then
        ip route del 192.168.15.0/24 dev "${VPN_NAME}" 2>/dev/null || true
        log_info "Na rede local — rota LAN via VPN removida (evita conflito)."
    fi

    sleep 3

    # Verificar handshake
    local handshake
    handshake=$(wg show "${VPN_NAME}" 2>/dev/null | grep "latest handshake" || true)
    if [ -n "${handshake}" ]; then
        log_ok "VPN conectada!"
        cmd_status
    else
        local transfer
        transfer=$(wg show "${VPN_NAME}" 2>/dev/null | grep "transfer" || true)
        if echo "${transfer}" | grep -q "received"; then
            log_ok "VPN conectada (handshake em progresso)."
        else
            log_warn "VPN ativa mas sem handshake ainda. Aguarde alguns segundos..."
            log_info "Verifique: sudo rpa4all-vpn status"
        fi
    fi
}

cmd_down() {
    need_root down
    log_info "Desconectando VPN..."
    nmcli connection down "${NM_CONN}" 2>/dev/null || \
        wg-quick down "${WG_CONF}" 2>/dev/null || \
        ip link delete "${VPN_NAME}" 2>/dev/null || true
    log_ok "VPN desconectada."
}

cmd_status() {
    echo -e "${BOLD}═══ RPA4All VPN Status ═══${NC}"
    echo ""

    if ip link show "${VPN_NAME}" &>/dev/null; then
        log_ok "Interface: ${VPN_NAME} (UP)"

        local ip_addr
        ip_addr=$(ip -4 addr show "${VPN_NAME}" 2>/dev/null | grep -oP 'inet \K[0-9.]+' || echo "?")
        echo -e "  IP VPN:     ${CYAN}${ip_addr}${NC}"

        local endpoint
        endpoint=$(wg show "${VPN_NAME}" 2>/dev/null | grep "endpoint" | awk '{print $2}' || echo "?")
        echo -e "  Endpoint:   ${endpoint}"

        local handshake
        handshake=$(wg show "${VPN_NAME}" 2>/dev/null | grep "latest handshake" | sed 's/.*: //' || echo "nenhum")
        echo -e "  Handshake:  ${handshake}"

        local transfer
        transfer=$(wg show "${VPN_NAME}" 2>/dev/null | grep "transfer" | sed 's/.*: //' || echo "0")
        echo -e "  Transfer:   ${transfer}"

        # Testar conectividade
        if ping -c 1 -W 2 10.66.66.1 &>/dev/null; then
            log_ok "Gateway 10.66.66.1 acessível"
        else
            log_warn "Gateway 10.66.66.1 não responde"
        fi
    else
        log_warn "Interface: ${VPN_NAME} (DOWN)"
        echo -e "  Use: ${CYAN}sudo rpa4all-vpn up${NC}"
    fi
    echo ""
}

cmd_update_endpoint() {
    need_root update-endpoint
    /usr/bin/rpa4all-vpn-update-endpoint
}

cmd_pubkey() {
    local keyfile="/var/lib/rpa4all-vpn/public.key"
    # Fallback para local protegido (com sudo)
    [ ! -f "${keyfile}" ] && keyfile="/etc/wireguard/rpa4all-public.key"
    if [ -f "${keyfile}" ] && [ -r "${keyfile}" ]; then
        echo -e "Chave pública: ${CYAN}$(cat "${keyfile}")${NC}"
        echo "Envie esta chave ao admin para registrar no servidor VPN."
    else
        log_err "Chave não encontrada. Use: sudo rpa4all-vpn pubkey"
    fi
}

cmd_logs() {
    if command -v journalctl &>/dev/null; then
        journalctl -u "NetworkManager" --since "1 hour ago" | grep -i "wireguard\|rpa4all\|wg" | tail -30
    else
        log_warn "journalctl não disponível."
    fi
}

cmd_help() {
    cat << EOF
${BOLD}rpa4all-vpn${NC} v${VERSION} — VPN WireGuard para homelab RPA4All

${BOLD}USO:${NC}
  sudo rpa4all-vpn <comando>

${BOLD}COMANDOS:${NC}
  ${CYAN}up${NC}                Conectar VPN
  ${CYAN}down${NC}              Desconectar VPN
  ${CYAN}status${NC}            Mostrar estado da conexão
  ${CYAN}update-endpoint${NC}   Atualizar IP do endpoint (DDNS)
  ${CYAN}pubkey${NC}            Mostrar chave pública (para registro)
  ${CYAN}logs${NC}              Últimos logs relevantes
  ${CYAN}help${NC}              Mostrar esta ajuda

${BOLD}PORTAL:${NC}
  https://auth.rpa4all.com/vpn/

${BOLD}ARQUIVOS:${NC}
  /etc/wireguard/rpa4all.conf          Config WireGuard
  /etc/wireguard/rpa4all-public.key    Chave pública
  /etc/NetworkManager/system-connections/rpa4all-vpn.nmconnection

EOF
}

# ── Main ──
case "${1:-help}" in
    up)               cmd_up ;;
    down)             cmd_down ;;
    status)           cmd_status ;;
    update-endpoint)  cmd_update_endpoint ;;
    pubkey)           cmd_pubkey ;;
    logs)             cmd_logs ;;
    help|--help|-h)   cmd_help ;;
    version|--version|-v) echo "rpa4all-vpn v${VERSION}" ;;
    *)
        log_err "Comando desconhecido: $1"
        cmd_help
        exit 1
        ;;
esac
