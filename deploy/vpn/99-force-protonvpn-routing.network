# /etc/systemd/network/99-force-protonvpn-routing.network
# 🔒 FORÇA rota padrão via ProtonVPN (protonvpn)
# ⚠️ PRIORIDADE MÁXIMA — sobrescreve configs anteriores
# NUNCA será sobrescrito por netplan ou outro sistema
#
# Regra: Se protonvpn existir, TODO tráfego geral (não-WireGuard) sai via ProtonVPN
# Fallback: Se protonvpn não existir, usa eth-onboard (temporário, ativa alerta)

[Match]
Name=protonvpn

[Network]
DHCP=no
ConfigureWithoutCarrier=yes

[Route]
# ⭐ Rota padrão para ProtonVPN — PRIORIDADE 100 (máxima)
Destination=0.0.0.0/0
GatewayOnLink=yes
# Priority mais ALTA que eth-onboard (que tem 600)
Priority=50

[RoutingPolicyRule]
# Força via tabela 205
Table=205
Priority=50

# ─────────────────────────────────────────────────────────
# FALLBACK: Se protonvpn não conseguir rotear em 30s,
# ativa eth-onboard com métrica > 600 (backup only)
# ─────────────────────────────────────────────────────────
