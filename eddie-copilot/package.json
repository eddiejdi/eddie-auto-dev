{
  "name": "shared-copilot",
  "displayName": "Shared Copilot",
  "description": "AI-powered code completion and chat assistant similar to GitHub Copilot, powered by Ollama",
  "version": "1.0.0",
  "publisher": "shared",
  "repository": {
    "type": "git",
    "url": "https://github.com/shared/shared-copilot"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "ai",
    "copilot",
    "autocomplete",
    "code-completion",
    "ollama",
    "assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shared-copilot.enable",
        "title": "Shared Copilot: Enable"
      },
      {
        "command": "shared-copilot.disable",
        "title": "Shared Copilot: Disable"
      },
      {
        "command": "shared-copilot.showStatus",
        "title": "Shared Copilot: Show Status"
      },
      {
        "command": "shared-copilot.triggerInline",
        "title": "Shared Copilot: Trigger Inline Suggestion"
      },
      {
        "command": "shared-copilot.acceptSuggestion",
        "title": "Shared Copilot: Accept Suggestion"
      },
      {
        "command": "shared-copilot.nextSuggestion",
        "title": "Shared Copilot: Next Suggestion"
      },
      {
        "command": "shared-copilot.previousSuggestion",
        "title": "Shared Copilot: Previous Suggestion"
      },
      {
        "command": "shared-copilot.dismissSuggestion",
        "title": "Shared Copilot: Dismiss Suggestion"
      },
      {
        "command": "shared-copilot.openChat",
        "title": "Shared Copilot: Open Chat"
      },
      {
        "command": "shared-copilot.explainCode",
        "title": "Shared Copilot: Explain This Code"
      },
      {
        "command": "shared-copilot.fixCode",
        "title": "Shared Copilot: Fix This Code"
      },
      {
        "command": "shared-copilot.generateTests",
        "title": "Shared Copilot: Generate Tests"
      },
      {
        "command": "shared-copilot.addDocumentation",
        "title": "Shared Copilot: Add Documentation"
      },
      {
        "command": "shared-copilot.refactorCode",
        "title": "Shared Copilot: Refactor Code"
      },
      {
        "command": "shared-copilot.clearHistory",
        "title": "Shared Copilot: Clear Chat History"
      }
      ,
      {
        "command": "shared-copilot.selectModel",
        "title": "Shared Copilot: Select Model from Server"
      },
      {
        "command": "shared-copilot.homelabExecute",
        "title": "Shared Copilot: Homelab — Execute Command"
      },
      {
        "command": "shared-copilot.homelabHealth",
        "title": "Shared Copilot: Homelab — Server Health"
      },
      {
        "command": "shared-copilot.homelabDockerPs",
        "title": "Shared Copilot: Homelab — Docker Containers"
      },
      {
        "command": "shared-copilot.homelabDockerLogs",
        "title": "Shared Copilot: Homelab — Docker Logs"
      },
      {
        "command": "shared-copilot.homelabSystemdStatus",
        "title": "Shared Copilot: Homelab — Service Status"
      },
      {
        "command": "shared-copilot.homelabSystemdRestart",
        "title": "Shared Copilot: Homelab — Restart Service"
      },
      {
        "command": "shared-copilot.homelabLogs",
        "title": "Shared Copilot: Homelab — Service Logs"
      }
    ],
    "keybindings": [
      {
        "command": "shared-copilot.triggerInline",
        "key": "alt+\\",
        "mac": "alt+\\",
        "when": "editorTextFocus && !inlineSuggestionVisible"
      },
      {
        "command": "shared-copilot.acceptSuggestion",
        "key": "ctrl+tab",
        "mac": "ctrl+tab",
        "when": "editorTextFocus && inlineSuggestionVisible && !editorTabMovesFocus"
      },
      {
        "command": "shared-copilot.nextSuggestion",
        "key": "alt+]",
        "mac": "alt+]",
        "when": "editorTextFocus && inlineSuggestionVisible"
      },
      {
        "command": "shared-copilot.previousSuggestion",
        "key": "alt+[",
        "mac": "alt+[",
        "when": "editorTextFocus && inlineSuggestionVisible"
      },
      {
        "command": "shared-copilot.dismissSuggestion",
        "key": "escape",
        "mac": "escape",
        "when": "editorTextFocus && inlineSuggestionVisible"
      },
      {
        "command": "shared-copilot.openChat",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "configuration": {
      "title": "Shared Copilot",
      "properties": {
        "shared-copilot.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Shared Copilot"
        },
        "shared-copilot.ollamaUrl": {
          "type": "string",
          "default": "http://192.168.15.2:11434",
          "description": "Ollama API URL (local). Default: homelab na rede local."
        },
        "shared-copilot.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "Model for code completion (use lightweight model for speed)"
        },
        "shared-copilot.chatModel": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "Model for local chat fallback"
        },
        "shared-copilot.useHomelab": {
          "type": "boolean",
          "default": true,
          "description": "Use Homelab integration (local + remote routing)"
        },
        "shared-copilot.remoteUrl": {
          "type": "string",
          "default": "http://192.168.15.2:3000",
          "description": "Remote Open WebUI server URL. Default: homelab na rede local."
        },
        "shared-copilot.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Open WebUI authentication"
        },
        "shared-copilot.localModel": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "Lightweight local model for fast autocomplete"
        },
        "shared-copilot.remoteModel": {
          "type": "string",
          "default": "shared-coder:latest",
          "description": "Remote model for complex tasks (chat, refactoring)"
        },
        "shared-copilot.remoteEmail": {
          "type": "string",
          "default": "",
          "description": "Email for Open WebUI auto-login (JWT). Used when apiKey is not set."
        },
        "shared-copilot.remotePassword": {
          "type": "string",
          "default": "",
          "description": "Password for Open WebUI auto-login (JWT). Used when apiKey is not set."
        },
        "shared-copilot.useRemote": {
          "type": "boolean",
          "default": true,
          "description": "Enable remote server for complex tasks"
        },
        "shared-copilot.complexityThreshold": {
          "type": "number",
          "default": 100,
          "description": "Character threshold to trigger remote model"
        },
        "shared-copilot.maxTokens": {
          "type": "number",
          "default": 500,
          "description": "Maximum tokens for completion"
        },
        "shared-copilot.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Temperature for generation (0.0-1.0)"
        },
        "shared-copilot.debounceTime": {
          "type": "number",
          "default": 300,
          "description": "Debounce time in milliseconds before triggering completion"
        },
        "shared-copilot.contextLines": {
          "type": "number",
          "default": 50,
          "description": "Number of context lines to send to the model"
        },
        "shared-copilot.enableAutoComplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic inline suggestions while typing"
        },
        "shared-copilot.suggestionDelay": {
          "type": "number",
          "default": 500,
          "description": "Delay in milliseconds before showing suggestions"
        },
        "shared-copilot.inlineSuggestMode": {
          "type": "string",
          "enum": ["prefix", "subword", "subwordSmart"],
          "default": "prefix",
          "description": "Inline suggestion trigger mode"
        },
        "shared-copilot.agentsApiUrl": {
          "type": "string",
          "default": "http://localhost:8503",
          "description": "URL da API de agentes especializados (Homelab Agent). Somente acessível via rede local."
        }
        ,
        "shared-copilot.knownAgents": {
          "type": "array",
          "default": ["python","javascript","typescript","go","rust","java","csharp","php"],
          "description": "Lista conhecida de agentes/languages que o Copilot pode utilizar quando a API não está disponível."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shared-copilot-sidebar",
          "title": "Shared Copilot",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "shared-copilot-sidebar": [
        {
          "type": "webview",
          "id": "shared-copilot.chatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "shared-copilot.contextMenu",
          "group": "shared-copilot"
        }
      ],
      "shared-copilot.contextMenu": [
        {
          "command": "shared-copilot.explainCode",
          "when": "editorHasSelection"
        },
        {
          "command": "shared-copilot.fixCode",
          "when": "editorHasSelection"
        },
        {
          "command": "shared-copilot.generateTests",
          "when": "editorHasSelection"
        },
        {
          "command": "shared-copilot.addDocumentation",
          "when": "editorHasSelection"
        },
        {
          "command": "shared-copilot.refactorCode",
          "when": "editorHasSelection"
        }
      ]
    },
    "submenus": [
      {
        "id": "shared-copilot.contextMenu",
        "label": "Shared Copilot"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
