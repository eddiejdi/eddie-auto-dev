      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{job=\"node-exporter\",instance=\"node-exporter:9100\",mountpoint=\"/mnt/raid1\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",instance=\"node-exporter:9100\",mountpoint=\"/mnt/raid1\",fstype!~\"tmpfs|overlay|squashfs\"}))",
