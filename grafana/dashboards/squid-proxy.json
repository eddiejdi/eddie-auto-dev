          "refId": "A"
        },
        {
          "expr": "squid_cache_hit_ratio_requests_percent{window=\"60min\"}",
          "legendFormat": "Requests 60m",
          "refId": "B"
        },
        {
          "expr": "squid_cache_hit_ratio_bytes_percent{window=\"5min\"}",
          "legendFormat": "Bytes 5m",
          "refId": "C"
        },
        {
          "expr": "squid_cache_hit_ratio_bytes_percent{window=\"60min\"}",
          "legendFormat": "Bytes 60m",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
