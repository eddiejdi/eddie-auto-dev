{
  "id": null,
  "uid": "squid-proxy-overview",
  "title": "Squid Proxy Overview",
  "description": "Saude, throughput e hit ratio do Squid proxy do homelab",
  "tags": [
    "squid",
    "proxy",
    "homelab",
    "network"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Squid Up",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "title": "Clientes Ativos",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_clients_accessing_cache",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Req/s (5m)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.requests\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Hit Ratio Req 5m",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_cache_hit_ratio_requests_percent{window=\"5min\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Falha de Requisicao",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_request_failure_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Cliente HTTP - Throughput",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.requests\"}",
          "legendFormat": "requests/s",
          "refId": "A"
        },
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.hits\"}",
          "legendFormat": "hits/s",
          "refId": "B"
        },
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.errors\"}",
          "legendFormat": "errors/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "title": "Entrada/Saida de Dados",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "dfc0w4yioe4u8e"
      },
      "targets": [
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.kbytes_in\"}",
          "legendFormat": "client in KB/s",
          "refId": "A"
        },
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"client_http.kbytes_out\"}",
          "legendFormat": "client out KB/s",
          "refId": "B"
        },
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"server.all.kbytes_in\"}",
          "legendFormat": "server in KB/s",
          "refId": "C"
        },
        {
          "expr": "squid_manager_metric{section=\"5min\",metric=\"server.all.kbytes_out\"}",
          "legendFormat": "server out KB/s",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "title": "Hit Ratio",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
