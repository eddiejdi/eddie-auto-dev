      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_leases_active", "legendFormat": "leases ativos", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_pool_size", "legendFormat": "pool total", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "s",
          "decimals": 0
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "id": 9,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": {}, "textMode": "value_and_name" },
