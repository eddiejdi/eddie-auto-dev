      "title": "Status Atual",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "INATIVO" }, "1": { "text": "ATIVO" } }, "type": "value" }
          ],
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": {}, "textMode": "auto" },
      "title": "Serviço DHCP",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_service_up", "legendFormat": "dnsmasq", "refId": "A" }
