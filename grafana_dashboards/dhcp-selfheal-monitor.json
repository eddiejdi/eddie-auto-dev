      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_selfheal_restarts_total", "legendFormat": "restarts", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
