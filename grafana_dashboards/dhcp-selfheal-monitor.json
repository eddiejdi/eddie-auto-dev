      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_last_offer_age_seconds", "legendFormat": "último offer", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "title": "Histórico & Saúde",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "max": 1,
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Status dos Componentes DHCP",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_service_up", "legendFormat": "serviço ativo", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_socket_bound", "legendFormat": "socket UDP:67", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_nftables_rules_ok", "legendFormat": "nftables OK", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_responding", "legendFormat": "respondendo", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 11,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Ações de Selfheal ao Longo do Tempo",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "increase(dhcp_selfheal_restarts_total[1h])", "legendFormat": "restarts/hora", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "increase(dhcp_selfheal_nftables_fixes_total[1h])", "legendFormat": "fixes nftables/hora", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "unit": "s",
          "decimals": 0
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Idade do Último DHCPOFFER (alerta se > 300s com clientes ativos)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "dfc0w4yioe4u8e" }, "expr": "dhcp_last_offer_age_seconds", "legendFormat": "segundos desde último offer", "refId": "A" }
      ],
      "thresholds": {
        "mode": "line",
        "steps": [
          { "color": "transparent", "value": null },
          { "color": "orange", "value": 120 },
          { "color": "red", "value": 300 }
        ]
      }
    }
