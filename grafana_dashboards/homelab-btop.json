{
  "dashboard": {
    "uid": "homelab-btop",
    "title": "Homelab System Monitor (btop)",
    "description": "Equivalente ao btop do homelab: CPU, Memory, Network, Disks, GPU0 (RTX 2060), GPU1 (GTX 1050), Processes",
    "tags": ["homelab", "btop", "system"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "fiscalYearStartMonth": 0,
    "liveNow": true,
    "panels": [
      {
        "id": 1,
        "title": "System Info",
        "type": "stat",
        "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Uptime" }, "properties": [{ "id": "unit", "value": "dtdurations" }] },
            { "matcher": { "id": "byName", "options": "Load 1m" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 14 }] } }] },
            { "matcher": { "id": "byName", "options": "Load 5m" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 14 }] } }] },
            { "matcher": { "id": "byName", "options": "Load 15m" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 14 }] } }] },
            { "matcher": { "id": "byName", "options": "CPU Freq" }, "properties": [{ "id": "unit", "value": "hertz" }] }
          ]
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
        "targets": [
          { "expr": "time() - node_boot_time_seconds{job=\"node-exporter\"}", "legendFormat": "Uptime", "refId": "A" },
          { "expr": "node_load1{job=\"node-exporter\"}", "legendFormat": "Load 1m", "refId": "B" },
          { "expr": "node_load5{job=\"node-exporter\"}", "legendFormat": "Load 5m", "refId": "C" },
          { "expr": "node_load15{job=\"node-exporter\"}", "legendFormat": "Load 15m", "refId": "D" },
          { "expr": "count(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"})", "legendFormat": "CPU Cores", "refId": "E" },
          { "expr": "avg(node_cpu_frequency_max_hertz{job=\"node-exporter\"})", "legendFormat": "CPU Freq", "refId": "F" }
        ]
      },
      {
        "id": 2,
        "title": "CPU Usage %",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "gradientMode": "opacity", "spanNulls": false, "stacking": { "mode": "none" }, "axisBorderShow": false },
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
        "targets": [
          { "expr": "(1 - avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[1m]))) * 100", "legendFormat": "Total", "refId": "A" },
          { "expr": "avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"user\"}[1m])) * 100", "legendFormat": "User", "refId": "B" },
          { "expr": "avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"system\"}[1m])) * 100", "legendFormat": "System", "refId": "C" },
          { "expr": "avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"iowait\"}[1m])) * 100", "legendFormat": "IOWait", "refId": "D" }
        ]
      },
      {
        "id": 3,
        "title": "CPU Per-Core Usage %",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "gradientMode": "none", "spanNulls": false, "stacking": { "mode": "none" } },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
        "targets": [
          { "expr": "(1 - rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[1m])) * 100", "legendFormat": "Core {{cpu}}", "refId": "A" }
        ]
      },
      {
        "id": 4,
        "title": "CPU Package Temperature",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 11 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme" },
            "unit": "celsius",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 95 }] }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "node_hwmon_temp_celsius{chip=\"platform_coretemp_0\",sensor=\"temp1\"}", "legendFormat": "Package", "refId": "A" },
          { "expr": "node_hwmon_temp_celsius{chip=\"platform_coretemp_0\",sensor=~\"temp[2-9]\"}", "legendFormat": "Core {{sensor}}", "refId": "B" }
        ]
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 11 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "decbytes",
            "min": 0,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 21474836480 }, { "color": "red", "value": 28991029248 }] }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "RAM Used" }, "properties": [{ "id": "max", "value": 33622220800 }] },
            { "matcher": { "id": "byName", "options": "Swap Used" }, "properties": [{ "id": "max", "value": 16777216000 }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8000000000 }, { "color": "red", "value": 14000000000 }] } }] }
          ]
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true, "showThresholdLabels": false, "orientation": "horizontal" },
        "targets": [
          { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}", "legendFormat": "RAM Used", "refId": "A" },
          { "expr": "node_memory_SwapTotal_bytes{job=\"node-exporter\"} - node_memory_SwapFree_bytes{job=\"node-exporter\"}", "legendFormat": "Swap Used", "refId": "B" }
        ]
      },
      {
        "id": 6,
        "title": "Memory Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "gradientMode": "opacity", "stacking": { "mode": "normal" } },
            "unit": "bytes"
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
        "targets": [
          { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"} - node_memory_Buffers_bytes{job=\"node-exporter\"} - node_memory_Cached_bytes{job=\"node-exporter\"}", "legendFormat": "Used", "refId": "A" },
          { "expr": "node_memory_Buffers_bytes{job=\"node-exporter\"}", "legendFormat": "Buffers", "refId": "B" },
          { "expr": "node_memory_Cached_bytes{job=\"node-exporter\"}", "legendFormat": "Cached", "refId": "C" },
          { "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter\"} - node_memory_MemFree_bytes{job=\"node-exporter\"}", "legendFormat": "Available (reclaimable)", "refId": "D" },
          { "expr": "node_memory_MemFree_bytes{job=\"node-exporter\"}", "legendFormat": "Free", "refId": "E" }
        ]
      },
      {
        "id": 7,
        "title": "Network Traffic (eth-onboard)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "opacity" },
            "unit": "Bps"
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Upload" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "rate(node_network_receive_bytes_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "Download", "refId": "A" },
          { "expr": "rate(node_network_transmit_bytes_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "Upload", "refId": "B" }
        ]
      },
      {
        "id": 8,
        "title": "Network Packets & Errors",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
            "unit": "pps"
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "TX Packets" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] },
            { "matcher": { "id": "byRegexp", "options": ".*Errors.*|.*Drops.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 2 }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "rate(node_network_receive_packets_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "RX Packets", "refId": "A" },
          { "expr": "rate(node_network_transmit_packets_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "TX Packets", "refId": "B" },
          { "expr": "rate(node_network_receive_errs_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "RX Errors", "refId": "C" },
          { "expr": "rate(node_network_transmit_errs_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "TX Errors", "refId": "D" },
          { "expr": "rate(node_network_receive_drop_total{job=\"node-exporter\",device=\"eth-onboard\"}[1m])", "legendFormat": "RX Drops", "refId": "E" }
        ]
      },
      {
        "id": 9,
        "title": "Disk Usage",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizHeight": 20 },
        "targets": [
          { "expr": "1 - (node_filesystem_avail_bytes{job=\"node-exporter\",fstype!~\"tmpfs|overlay|squashfs|efivarfs\",mountpoint!~\"/boot.*\"} / node_filesystem_size_bytes{job=\"node-exporter\",fstype!~\"tmpfs|overlay|squashfs|efivarfs\",mountpoint!~\"/boot.*\"})", "legendFormat": "{{mountpoint}}", "refId": "A" }
        ]
      },
      {
        "id": 10,
        "title": "Disk I/O",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "gradientMode": "opacity" },
            "unit": "Bps"
          },
          "overrides": [
            { "matcher": { "id": "byRegexp", "options": ".*Write.*" }, "properties": [{ "id": "custom.transform", "value": "negative-Y" }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
        "targets": [
          { "expr": "rate(node_disk_read_bytes_total{job=\"node-exporter\",device=~\"sd[a-z]+\"}[1m])", "legendFormat": "Read {{device}}", "refId": "A" },
          { "expr": "rate(node_disk_written_bytes_total{job=\"node-exporter\",device=~\"sd[a-z]+\"}[1m])", "legendFormat": "Write {{device}}", "refId": "B" }
        ]
      },
      {
        "id": 11,
        "title": "",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 12,
        "title": "GPU0 — RTX 2060 SUPER",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "nvidia_smi_utilization_gpu_ratio{uuid=\"6ba33090-c1ea-a939-7ac4-a7d7c6b4ba32\"} * 100", "legendFormat": "GPU Util %", "refId": "A" },
          { "expr": "nvidia_smi_utilization_memory_ratio{uuid=\"6ba33090-c1ea-a939-7ac4-a7d7c6b4ba32\"} * 100", "legendFormat": "Mem Util %", "refId": "B" }
        ]
      },
      {
        "id": 13,
        "title": "GPU0 — Temperature & Power",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Temperature" }, "properties": [{ "id": "unit", "value": "celsius" }, { "id": "custom.axisPlacement", "value": "left" }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "Power" }, "properties": [{ "id": "unit", "value": "watt" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "nvidia_smi_temperature_gpu{uuid=\"6ba33090-c1ea-a939-7ac4-a7d7c6b4ba32\"}", "legendFormat": "Temperature", "refId": "A" },
          { "expr": "nvidia_smi_power_draw_watts{uuid=\"6ba33090-c1ea-a939-7ac4-a7d7c6b4ba32\"}", "legendFormat": "Power", "refId": "B" }
        ]
      },
      {
        "id": 14,
        "title": "GPU0 — VRAM",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "bytes",
            "min": 0,
            "max": 8589934592,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 6000000000 }, { "color": "red", "value": 7500000000 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true, "orientation": "horizontal" },
        "targets": [
          { "expr": "nvidia_smi_memory_used_bytes{uuid=\"6ba33090-c1ea-a939-7ac4-a7d7c6b4ba32\"}", "legendFormat": "RTX 2060 VRAM Used", "refId": "A" }
        ]
      },
      {
        "id": 15,
        "title": "GPU1 — GTX 1050",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "nvidia_smi_utilization_gpu_ratio{uuid=\"29e83e3f-86ab-1f75-02ce-0a08285f970f\"} * 100", "legendFormat": "GPU Util %", "refId": "A" },
          { "expr": "nvidia_smi_utilization_memory_ratio{uuid=\"29e83e3f-86ab-1f75-02ce-0a08285f970f\"} * 100", "legendFormat": "Mem Util %", "refId": "B" }
        ]
      },
      {
        "id": 16,
        "title": "GPU1 — Temperature & Power",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Temperature" }, "properties": [{ "id": "unit", "value": "celsius" }, { "id": "custom.axisPlacement", "value": "left" }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "Power" }, "properties": [{ "id": "unit", "value": "watt" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
        "targets": [
          { "expr": "nvidia_smi_temperature_gpu{uuid=\"29e83e3f-86ab-1f75-02ce-0a08285f970f\"}", "legendFormat": "Temperature", "refId": "A" },
          { "expr": "nvidia_smi_power_draw_watts{uuid=\"29e83e3f-86ab-1f75-02ce-0a08285f970f\"}", "legendFormat": "Power", "refId": "B" }
        ]
      },
      {
        "id": 17,
        "title": "GPU1 — VRAM",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
        "datasource": { "uid": "dfc0w4yioe4u8e", "type": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "unit": "bytes",
            "min": 0,
            "max": 2147483648,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1500000000 }, { "color": "red", "value": 1900000000 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true, "orientation": "horizontal" },
        "targets": [
          { "expr": "nvidia_smi_memory_used_bytes{uuid=\"29e83e3f-86ab-1f75-02ce-0a08285f970f\"}", "legendFormat": "GTX 1050 VRAM Used", "refId": "A" }
        ]
      },
      {
        "id": 18,
