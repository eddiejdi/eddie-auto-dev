{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./tools/copilot_hooks/post_edit_validate.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./tools/copilot_hooks/pre_tool_guardrails.py"
          }
        ]
      }
    ]
  }
}