{
  "id": null,
  "uid": "tape-component-quality-v1",
  "title": "Tape Component Quality",
  "tags": ["ltfs", "tape", "fc", "quality", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Overall Quality",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "dfc0w4yioe4u8e"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "tape_component_quality_overall_score",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "green", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Last Collection",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "dfc0w4yioe4u8e"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "tape_component_quality_last_run_timestamp_seconds",
          "instant": true
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Component Scores",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "dfc0w4yioe4u8e"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "tape_component_quality_score",
          "legendFormat": "{{component}}",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "green", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "HBA Quality Trend",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "dfc0w4yioe4u8e"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "refId": "A",
          "expr": "tape_component_quality_score{category=\"hba\"}",
          "legendFormat": "{{component}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "green", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Component Status Codes",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "dfc0w4yioe4u8e"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "refId": "A",
          "expr": "tape_component_quality_status_code",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {"displayName": "Value", "desc": false}
        ]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"0": {"text": "fail", "color": "red"}}},
                  {"type": "value", "options": {"1": {"text": "degraded", "color": "yellow"}}},
                  {"type": "value", "options": {"2": {"text": "pass", "color": "green"}}}
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "time": {"from": "now-24h", "to": "now"}
}
