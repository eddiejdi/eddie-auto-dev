+# --- New helper: check_circuit_breaker(conn, config, symbol) ---
+def check_circuit_breaker(pg_conn, config: dict, symbol: str) -> bool:
+    """Return True if trading allowed; False if circuit should pause trading.
+
+    Expects `btc.trades` and `btc.decisions` tables to exist. Uses simple SQL
+    aggregates to compute win_rate (24h) and daily_pnl (since UTC midnight).
+    """
+    cb = config.get("circuit_breaker", {}) if config else {}
+    enabled = cb.get("enabled", CIRCUIT_BREAKER_DEFAULTS["enabled"])
+    if not enabled:
+        return True
+
+    min_win = float(cb.get("min_win_rate_24h", CIRCUIT_BREAKER_DEFAULTS["min_win_rate_24h"]))
+    max_loss = float(cb.get("max_daily_loss_usd", CIRCUIT_BREAKER_DEFAULTS["max_daily_loss_usd"]))
+
+    try:
+        cur = pg_conn.cursor()
+        # Win rate last 24h
+        cur.execute(
+            "SELECT COUNT(*) FILTER (WHERE pnl > 0) AS wins, COUNT(*) AS total FROM btc.trades "
+            "WHERE symbol = %s AND to_timestamp(timestamp) > now() - interval '24 hours';",
+            (symbol,)
+        )
+        wins, total = cur.fetchone()
+        win_rate = (wins / total) if total and total > 0 else 0.0
+
+        # Daily pnl (UTC day)
+        cur.execute(
+            "SELECT COALESCE(SUM(pnl),0) FROM btc.trades WHERE symbol = %s AND to_timestamp(timestamp) >= date_trunc('day', now());",
+            (symbol,)
+        )
+        daily_pnl = float(cur.fetchone()[0] or 0.0)
+
+        if win_rate < min_win or daily_pnl < -abs(max_loss):
+            # Log and return False to indicate trading should be paused
+            log.critical("Circuit-breaker triggered for %s: win_rate=%.2f daily_pnl=%.2f (min_win=%.2f max_loss=%.2f)", symbol, win_rate, daily_pnl, min_win, max_loss)
+            return False
+        return True
+    except Exception as e:
+        # On DB errors, be conservative and allow trading (but log warning)
+        log.warning("Circuit-breaker DB check failed: %s — allowing trading", e)
+        return True
+
