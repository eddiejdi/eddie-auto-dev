#!/usr/bin/env bash
# tape-read-wrap: serializa acesso de LEITURA à fita LTO via flock compartilhado.
#
# Drain (lto6-drain-backups) e flush (ltfs-cache-flush) adquirem lock EXCLUSIVO.
# Este wrapper adquire lock COMPARTILHADO: múltiplas leituras em paralelo são OK,
# mas são bloqueadas enquanto drain/flush estiverem rodando, e vice-versa.
#
# Uso: tape-read-wrap [--timeout SECS] -- cmd [args...]
# Instalar em: /usr/local/sbin/tape-read-wrap
#
# Exemplos:
#   tape-read-wrap -- rsync nas:/mnt/tape/lto6/backup/ /destino/
#   tape-read-wrap -- tar -xf /mnt/tape/lto6/arquivo.tar -C /destino/
set -euo pipefail

LOCK_FILE="${TAPE_ACCESS_LOCK:-/run/ltfs-tape-access.lock}"
STATE_FILE="${TAPE_ACCESS_STATE:-/run/ltfs-tape-access.state}"
TIMEOUT="${TAPE_READ_TIMEOUT:-3600}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --timeout) TIMEOUT="$2"; shift 2 ;;
        --) shift; break ;;
        *) break ;;
    esac
done

if [[ $# -eq 0 ]]; then
    echo "Uso: tape-read-wrap [--timeout SECS] -- cmd [args...]" >&2
    exit 1
fi

_log() { printf "%s [tape-read-wrap] %s\n" "$(date -Iseconds)" "$*" >&2; }
_log "aguardando lock compartilhado (timeout=${TIMEOUT}s): $*"

echo "$$:$(date -Iseconds):SHARED:$*" >> "$STATE_FILE" 2>/dev/null || true
cleanup() { sed -i "/^$$:/d" "$STATE_FILE" 2>/dev/null || true; }
trap cleanup EXIT INT TERM

exec flock --shared --timeout "$TIMEOUT" "$LOCK_FILE" -- "$@"
