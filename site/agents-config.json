{
  "openwebui_url": "https://openwebui.rpa4all.com/",
  "api_url": "http://192.168.15.2:8503",
  "homelab_url": "http://192.168.15.2:8503",
  "agents": {
    "homelab_only": true,
    "description": "Apenas agentes homelab funcionais são expostos",
    "language_agents": {
      "note": "Agentes de linguagem disponíveis no homelab: python, javascript, typescript, go, rust, java, csharp, php"
    },
    "specialized_agents": {
      "opensearch": {
        "id": "agent-opensearch",
        "icon": "🔍",
        "name": "OpenSearch",
        "description": "Busca semântica, indexação e observabilidade",
        "color": "#005EB8",
        "api_endpoint": "/opensearch/search",
        "capabilities": [
          "Busca full-text e semântica",
          "Indexação de código e logs",
          "RAG (k-NN vectors)",
          "Observabilidade e analytics",
          "Ingestão de logs",
          "Busca com embeddings"
        ]
      },
      "bn_acervo": {
        "id": "agent-bn-acervo",
        "icon": "🏛️",
        "name": "Acervo BN",
        "description": "Dossiê histórico de figuras públicas no acervo da Biblioteca Nacional com OCR, relações e grafo Mermaid",
        "color": "#7c3f00",
        "api_endpoint": "/bn-acervo/dossier",
        "capabilities": [
          "Busca resiliente no Sophia Web",
          "Pesquisa ampliada em jornais, revistas e imprensa da BN",
          "Fallback de busca em Sophia, Hemeroteca e BNDigital",
          "Leitura de páginas de detalhe em Firefox headless",
          "OCR de PDFs e imagens via Ollama no homelab",
          "Ranqueamento e síntese com 2 GPUs",
          "Dossiê de figura pública com referências",
          "Grafo Mermaid de entidades e vínculos",
          "Descrição textual de cada relacionamento"
        ]
      }
    }
  },
  "api_endpoints": {
    "list_models": "/v1/models",
    "chat_completions": "/v1/chat/completions",
    "list_agents": "/agents",
    "agent_info": "/agents/{language}",
    "agent_activate": "/agents/{language}/activate",
    "agents_as_models": "/agents/models"
  },
  "integration": {
    "ollama_compatible": true,
    "openai_compatible": true,
    "streaming_supported": false,
    "authentication": "none",
    "local_api_port": 8503,
    "homelab_api_port": 8503,
    "homelab_host": "192.168.15.2"
  },
  "features": {
    "language_agents": 8,
    "language_agents_source": "homelab_only",
    "specialized_agents": 2,
    "homelab_remote": true,
    "rag_integration": true,
    "docker_orchestration": true,
    "github_integration": true,
    "telegram_bridge": true
  },
  "documentation": {
    "readme": "https://github.com/eddiejdi/shared-auto-dev",
