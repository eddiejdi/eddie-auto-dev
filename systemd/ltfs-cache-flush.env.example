BUFFER_ROOT_LOCAL=/mnt/raid1/lto6-cache
BUFFER_ROOT_LEGACY=
PRIMARY_BUFFER_ROOT=/mnt/raid1/lto6-cache
TARGET_ROOTS=/mnt/lto6:/mnt/lto6b
STATE_FILE=/var/lib/ltfs-cache-flush/state.json
PLACEMENT_FILE=/var/lib/ltfs-cache-flush/placements.json
CATALOG_FILE=/var/lib/ltfs-cache-flush/catalog.jsonl
METRICS_FILE=/var/lib/prometheus/node-exporter/ltfs_cache_flush.prom
METRICS_STATE_FILE=/var/lib/ltfs-cache-flush/metrics-state.json
LOCK_FILE=/run/ltfs-cache-flush.lock
MIN_AGE_SECONDS=15
MIN_STABLE_SECONDS=30
HIGH_WATERMARK_PERCENT=85
LOW_WATERMARK_PERCENT=70
MIN_TARGET_TOTAL_BYTES=1099511627776
MIN_TARGET_FREE_BYTES=0
PLACEMENT_POLICY=most-free
LOG_LEVEL=INFO
