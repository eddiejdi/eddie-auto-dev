[Unit]
Description=Recover LTFS tape mount when it drops to read-only
After=ltfs-lto6.service lto6-metrics-export.service
Wants=lto6-metrics-export.service
Conflicts=ltfs-deep-recovery.service

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/ltfs-lto6
EnvironmentFile=-/etc/default/ltfs-recovery
ExecStart=/usr/bin/python3 /usr/local/tools/ltfs_recovery.py --self-heal
TimeoutStartSec=24h
KillMode=mixed
KillSignal=SIGTERM
FinalKillSignal=SIGKILL
