[Unit]
Description=Ollama Eddie Sentiment Pin Watchdog
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=homelab
WorkingDirectory=/home/homelab/ollama-warmup
ExecStart=/usr/bin/python3 /home/homelab/ollama-warmup/ollama_phi_pin.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
