[Unit]
Description=Ollama GPU Warmup — mantém phi4-mini carregado nas GPUs
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=edenilson
WorkingDirectory=/home/edenilson/eddie-auto-dev
ExecStart=/home/edenilson/eddie-auto-dev/.venv/bin/python3 /home/edenilson/eddie-auto-dev/scripts/ollama_warmup.py --verbose
TimeoutStartSec=120
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
