
# Arquivo: /home/homelab/.env.openwebui

# OAuth2 / OIDC - Authentik
# Open WebUI in production was validated with the OAuth-style env names below.
ANONYMIZED_TELEMETRY=false
ENV=prod
ENABLE_OAUTH_SIGNUP=true
OAUTH_PROVIDER_NAME=Authentik
OPENID_PROVIDER_URL=https://auth.rpa4all.com/application/o/openwebui/.well-known/openid-configuration
OAUTH_CLIENT_ID=authentik-openwebui
OAUTH_CLIENT_SECRET=openwebui-sso-secret-2026
OAUTH_SCOPES=openid email profile
