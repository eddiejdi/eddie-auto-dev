[Unit]
Description=Eddie Secrets Agent — gateway único para todos os secrets (v3.0 Authentik)
After=network.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=homelab
Group=homelab
WorkingDirectory=/home/homelab/agents_workspace/prod

# ── Configuração base ──
Environment=SECRETS_AGENT_API_KEY=please-set-a-strong-key
Environment=SECRETS_AGENT_DATA=/var/lib/eddie/secrets_agent
Environment=SECRETS_AGENT_PORT=8088
Environment=SECRETS_AGENT_PROM_PORT=8009

# ── Backend Authentik ──
Environment=AUTHENTIK_URL=https://auth.rpa4all.com
# Token de acesso à API do Authentik (Bearer token de um admin)
Environment=AUTHENTIK_TOKEN=please-set-authentik-token
# TTL do cache de disponibilidade do Authentik (segundos)
Environment=AUTHENTIK_STATUS_TTL=60

ExecStartPre=/bin/mkdir -p /var/lib/eddie/secrets_agent
ExecStart=/usr/bin/python3 /home/homelab/agents_workspace/prod/tools/secrets_agent/secrets_agent.py

Restart=always
RestartSec=5

MemoryMax=256M
MemoryHigh=192M

StandardOutput=journal
StandardError=journal
SyslogIdentifier=secrets-agent

[Install]
WantedBy=multi-user.target
