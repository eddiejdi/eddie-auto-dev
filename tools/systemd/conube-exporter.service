[Unit]
Description=Eddie Auto-Dev - Conube Exporter (Prometheus Metrics)
After=network.target specialized-agents-api.service
Wants=specialized-agents-api.service

[Service]
Type=simple
WorkingDirectory=/home/homelab/eddie-auto-dev
Environment="PATH=/home/homelab/eddie-auto-dev/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
Environment="SECRETS_AGENT_URL=http://127.0.0.1:8088"
Environment="CONUBE_SECRET_NAME=conube/rpa4all"
Environment="CONUBE_EXPORTER_PORT=9662"
Environment="CONUBE_EXPORTER_CACHE_SECONDS=300"
Environment="CONUBE_EXPORTER_HEADLESS=1"
Environment="CONUBE_EXPORTER_MONTHS_BACK=12"
Environment="CONUBE_CHROME_BINARY=/usr/bin/chromium-browser"
ExecStart=/home/homelab/eddie-auto-dev/.venv/bin/python3 /home/homelab/eddie-auto-dev/tools/conube_exporter.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=conube-exporter

[Install]
WantedBy=default.target
