{
  "manifest_version": 2,
  "name": "RPA4ALL Test Mass Autofill",
  "description": "Consulta massas de teste no ambiente RPA4ALL e preenche formularios automaticamente.",
  "version": "1.2.2",
  "update_url": "https://www.rpa4all.com/extension-updates/rpa4all-autofill.xml",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "file:///*",
    "https://*.rpa4all.com/*",
    "https://api.rpa4all.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "RPA4ALL Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["file:///*", "https://*.rpa4all.com/*"],
      "js": ["autofill-core.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rpa4all-test-mass-autofill@rpa4all.com",
      "strict_min_version": "121.0"
    }
  }
}
